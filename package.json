{
  "name": "vjml",
  "version": "0.1.0",
  "description": "Vue MJML-style email components with a plain Vue plugin and browser renderer.",
  "type": "module",
  "private": false,
  "main": "./dist/vjml.cjs",
  "module": "./dist/vjml.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/vjml.js",
      "require": "./dist/vjml.cjs"
    }
  },
  "keywords": [
    "vue",
    "plugin",
    "email",
    "mjml",
    "vite",
    "typescript"
  ],
  "scripts": {
    "dev": "vite",
    "dev:playground": "vite",
    "build": "npm run build:lib",
    "build:lib": "vite build && npm run build:types",
    "build:types": "vue-tsc -p tsconfig.lib.json",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && vue-tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run",
    "test:accordion": "vitest run test/components/accordion/accordion.test.ts"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^29.0.0",
    "mjml": "^4.18.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  }
}
