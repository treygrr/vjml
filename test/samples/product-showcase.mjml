<mjml lang='en'>
  <mj-head>
    <mj-html-attributes>
      <mj-selector path="div[role='article']">
        <mj-html-attribute name='data-sample'>product-showcase</mj-html-attribute>
      </mj-selector>
      <mj-selector path='.showcase-note div'>
        <mj-html-attribute name='data-block'>note</mj-html-attribute>
      </mj-selector>
    </mj-html-attributes>
  </mj-head>
  <mj-body background-color='#f5eee5' width='340px'>
    <mj-section background-color='#fffaf4' padding='20px 22px 12px'>
      <mj-column>
        <mj-text color='#173540' font-size='22px' font-weight='700' line-height='28px'>
          Product showcase
        </mj-text>
        <mj-spacer height='8px' />
        <mj-text css-class='showcase-note' color='#425d64' font-size='14px' line-height='22px'>
          Use this sample to compare root selectors, carousel output, and post-body CTA composition.
        </mj-text>
      </mj-column>
    </mj-section>
    <mj-section background-color='#fffaf4' padding='0px 22px 18px'>
      <mj-column>
        <mj-carousel
          padding='0px'
          tb-border='3px solid #d8c1a3'
          tb-border-radius='14px'
          tb-width='72px'
          thumbnails='supported'
        >
          <mj-carousel-image alt='Showcase one' href='https://example.com/gallery/1' src='https://dummyimage.com/600x220/16353f/fffaf2.png&text=Gallery+1' thumbnails-src='https://dummyimage.com/144x96/16353f/fffaf2.png&text=G1' />
          <mj-carousel-image alt='Showcase two' href='https://example.com/gallery/2' src='https://dummyimage.com/600x220/b96b37/fffaf2.png&text=Gallery+2' thumbnails-src='https://dummyimage.com/144x96/b96b37/fffaf2.png&text=G2' />
          <mj-carousel-image alt='Showcase three' href='https://example.com/gallery/3' src='https://dummyimage.com/600x220/246f6d/fffaf2.png&text=Gallery+3' thumbnails-src='https://dummyimage.com/144x96/246f6d/fffaf2.png&text=G3' />
        </mj-carousel>
      </mj-column>
    </mj-section>
    <mj-section background-color='#fff6ec' padding='0px 22px 22px'>
      <mj-column>
        <mj-divider border-color='#d9c5ad' border-width='1px' padding='12px 0px' />
        <mj-button
          align='left'
          background-color='#16353f'
          border-radius='999px'
          color='#fffaf2'
          href='https://example.com/gallery'
          inner-padding='10px 16px'
        >
          View collection
        </mj-button>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>