<mjml lang="en">
  <mj-head>
    <mj-attributes>
      <mj-table cellpadding="6" color="#425d64" font-size="13px" line-height="20px" padding="0px" />
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#f7efe4" width="340px">
    <mj-section background-color="#fffdf8" padding="20px">
      <mj-column>
        <mj-text color="#173540" font-size="15px" font-weight="700" line-height="22px">
          Shared table defaults
        </mj-text>

        <mj-spacer height="12px" />

        <mj-table>
          <tr><td><strong>Segment</strong></td><td>Lifecycle</td></tr>
          <tr><td><strong>Send</strong></td><td>Weekly</td></tr>
        </mj-table>

        <mj-spacer height="12px" />

        <mj-table color="#173540" width="auto">
          <tr><td><strong>Owner</strong></td><td>Growth</td></tr>
        </mj-table>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>