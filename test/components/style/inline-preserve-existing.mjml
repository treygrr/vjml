<mjml lang="en">
  <mj-head>
    <mj-style inline="inline">
      .preserve-text div {
        color:#db7636;
      }
    </mj-style>
  </mj-head>
  <mj-body width="340px" background-color="#f5eee6">
    <mj-section background-color="#fffaf5" padding="22px">
      <mj-column>
        <mj-text css-class="preserve-text" color="#173540" font-size="18px" font-weight="700" line-height="24px">
          Existing inline color wins
        </mj-text>
        <mj-spacer height="8px" />
        <mj-text color="#425d64" font-size="14px" line-height="22px">
          Non-important inline stylesheet rules should not replace explicit component styles already in the markup.
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>