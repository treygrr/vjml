<mjml lang="en">
  <mj-head>
    <mj-style>
      .style-note div { color:#0c7a7f; font-weight:700; letter-spacing:0.04em; }
    </mj-style>
  </mj-head>
  <mj-body width="340px" background-color="#f7efe4">
    <mj-section background-color="#fffdf8" padding="22px">
      <mj-column>
        <mj-text css-class="style-note" color="#173540" font-size="18px" font-weight="700" line-height="24px">
          Custom head styles
        </mj-text>
        <mj-spacer height="10px" />
        <mj-text color="#425d64" font-size="14px" line-height="22px">
          Use Style for renderer-collected CSS you want emitted into the final email document head.
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>