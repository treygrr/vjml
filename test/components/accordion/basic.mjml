<mjml lang="en">
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-accordion>
          <mj-accordion-element>
            <mj-accordion-title>Shipping updates</mj-accordion-title>
            <mj-accordion-text>
              Track the latest status of your order without leaving your inbox.
            </mj-accordion-text>
