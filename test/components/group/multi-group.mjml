<mjml lang="en">
  <mj-body background-color="#f7efe5" width="340px">
    <mj-section background-color="#fff8ef" padding="18px">
      <mj-group background-color="#f4e3d3" width="50%">
        <mj-column width="50%">
          <mj-text color="#173540" font-size="14px" font-weight="700" line-height="20px">
            North
          </mj-text>
        </mj-column>
        <mj-column width="50%">
          <mj-text color="#173540" font-size="14px" font-weight="700" line-height="20px">
            South
          </mj-text>
        </mj-column>
      </mj-group>
      <mj-group background-color="#efe0cf" width="50%">
        <mj-column width="50%">
          <mj-text color="#173540" font-size="14px" font-weight="700" line-height="20px">
            East
          </mj-text>
        </mj-column>
        <mj-column width="50%">
          <mj-text color="#173540" font-size="14px" font-weight="700" line-height="20px">
            West
          </mj-text>
        </mj-column>
      </mj-group>
    </mj-section>
  </mj-body>
</mjml>