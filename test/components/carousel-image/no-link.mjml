<mjml lang="en">
  <mj-body background-color="#f4ede3" width="340px">
    <mj-section background-color="#fff9f1" padding="20px">
      <mj-column>
        <mj-carousel border-radius="12px" padding="0px" thumbnails="hidden">
          <mj-carousel-image alt="Static slide" src="https://dummyimage.com/600x220/16353f/fffaf2.png&text=Static" title="Static catalog" />
          <mj-carousel-image alt="Linked slide" href="https://example.com/catalog" rel="nofollow" src="https://dummyimage.com/600x220/8e5f3d/fffaf2.png&text=Catalog" title="Catalog" />
        </mj-carousel>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>