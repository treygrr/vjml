<mjml lang="en">
  <mj-head>
    <mj-attributes>
      <mj-text color="#425d64" font-size="14px" line-height="22px" padding="0px" />
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#f7efe4" width="340px">
    <mj-section background-color="#fffdf8" padding="20px">
      <mj-column>
        <mj-text>
          Head attributes should define the base text styling.
        </mj-text>

        <mj-text color="#173540" font-weight="700" padding-top="12px">
          Explicit text attributes should still win after inheritance.
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>