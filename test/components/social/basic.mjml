<mjml lang="en">
  <mj-body background-color="#f7efe4" width="340px">
    <mj-section background-color="#fffdf8" padding="20px">
      <mj-column>
        <mj-social font-size="15px" icon-size="30px" mode="horizontal">
          <mj-social-element name="facebook" href="https://example.com/story">
            Facebook
          </mj-social-element>
          <mj-social-element name="linkedin" href="https://example.com/story">
            LinkedIn
          </mj-social-element>
          <mj-social-element name="x" href="https://example.com/story">
            X
          </mj-social-element>
        </mj-social>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>