<mjml lang="en">
  <mj-head>
    <mj-title>Weekly summary</mj-title>
    <mj-preview>Open for this week's highlights.</mj-preview>
  </mj-head>
  <mj-body background-color="#f7efe4" width="340px">
    <mj-section background-color="#fffdf8" padding="22px">
      <mj-column>
        <mj-text color="#173540" font-size="18px" font-weight="700" line-height="24px">
          Head-driven metadata
        </mj-text>
        <mj-spacer height="10px" />
        <mj-text color="#425d64" font-size="14px" line-height="22px">
          Use Head to collect preview text, title, fonts, styles, and attribute declarations before client render.
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>