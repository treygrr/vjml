<mjml lang="en">
  <mj-body background-color="#eef3f8" width="340px">
    <mj-wrapper background-color="#ffffff" gap="12px" padding="0px">
      <mj-section background-color="#fffdf8" padding="18px">
        <mj-column>
          <mj-text color="#173540" font-size="16px" font-weight="700" line-height="24px">
            First panel
          </mj-text>
        </mj-column>
      </mj-section>
      <mj-section background-color="#f8fafc" padding="18px">
        <mj-column>
          <mj-text color="#425d64" font-size="14px" line-height="22px">
            Gap should separate sibling sections inside the wrapper.
          </mj-text>
        </mj-column>
      </mj-section>
    </mj-wrapper>
  </mj-body>
</mjml>