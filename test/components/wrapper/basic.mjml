<mjml lang="en">
  <mj-body background-color="#f7efe4" width="340px">
    <mj-wrapper background-color="#fff2e7" padding="16px 0">
      <mj-section background-color="#fffdf8">
        <mj-column>
          <mj-text color="#173540" font-size="18px" font-weight="700" line-height="24px">
            Wrapper groups sections
          </mj-text>
          <mj-spacer height="10px" />
          <mj-text color="#425d64" font-size="14px" line-height="22px">
            Use Wrapper when you want a shared background or border treatment around multiple sections.
          </mj-text>
        </mj-column>
      </mj-section>
      <mj-section background-color="#fff8ef">
        <mj-column>
          <mj-button
            align="left"
            background-color="#16353f"
            border-radius="999px"
            color="#fffaf2"
            href="https://example.com"
            inner-padding="10px 16px"
          >
            Take action
          </mj-button>
        </mj-column>
      </mj-section>
    </mj-wrapper>
  </mj-body>
</mjml>