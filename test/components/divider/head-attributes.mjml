<mjml lang="en">
  <mj-head>
    <mj-attributes>
      <mj-divider border-color="#31566b" border-width="2px" padding="14px 0px" />
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#f7efe4" width="340px">
    <mj-section background-color="#fffdf8" padding="20px">
      <mj-column>
        <mj-text color="#173540" font-size="15px" font-weight="700" line-height="22px">
          Shared divider defaults
        </mj-text>

        <mj-divider />

        <mj-text color="#425d64" font-size="14px" line-height="22px">
          Head attributes should provide the divider border and spacing defaults.
        </mj-text>

        <mj-divider align="left" border-color="#db7636" padding-top="18px" width="42%" />
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>