<mjml lang="en">
  <mj-body background-color="#f7efe4" width="340px">
    <mj-section background-color="#fffdf8" padding="22px">
      <mj-column>
        <mj-button
          align="left"
          background-color="#db7636"
          border-radius="999px"
          color="#fffaf2"
          font-size="15px"
          font-weight="700"
          href="https://example.com/activity"
          inner-padding="12px 18px"
          line-height="18px"
          padding="0px"
          width="240px"
        >
          Review account activity
        </mj-button>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>