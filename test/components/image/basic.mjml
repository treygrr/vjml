<mjml lang="en">
  <mj-body background-color="#f7efe4" width="340px">
    <mj-section background-color="#fffdf8" padding="22px">
      <mj-column>
        <mj-image
          alt="Product preview"
          border-radius="18px"
          padding="0px"
          src="https://dummyimage.com/560x220/16353f/fffaf2.png&text=VJML+Image"
          width="280px"
        />

        <mj-spacer height="14px" />

        <mj-text color="#425d64" font-size="14px" line-height="22px">
          Use Image for product cards, banners, and editorial artwork.
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>