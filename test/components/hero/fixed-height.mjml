<mjml lang="en">
  <mj-body background-color="#f3efe7" width="340px">
    <mj-hero
      background-color="#25404a"
      background-height="320px"
      background-url="https://dummyimage.com/1200x600/25404a/fcf4eb.png&text=Fixed+Hero"
      background-width="340px"
      height="210px"
      inner-padding="24px"
      padding="0px"
      vertical-align="bottom"
    >
      <mj-text color="#fff8ee" font-size="22px" font-weight="700" line-height="28px">
        Limited seats
      </mj-text>
      <mj-spacer height="8px" />
      <mj-text color="#d9c9bb" font-size="13px" line-height="20px">
        Join the in-person workshop before registration closes on Friday.
      </mj-text>
      <mj-spacer height="12px" />
      <mj-button
        align="left"
        background-color="#f3c49a"
        border-radius="999px"
        color="#25404a"
        href="https://example.com/register"
        inner-padding="9px 15px"
      >
        Reserve seat
      </mj-button>
    </mj-hero>
  </mj-body>
</mjml>