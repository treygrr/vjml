<mjml lang="en">
  <mj-body background-color="#f7efe4" width="340px">
    <mj-hero
      background-color="#16353f"
      background-height="220px"
      background-url="https://dummyimage.com/960x420/16353f/fffaf2.png&text=Hero+Launch"
      background-width="340px"
      inner-padding="20px"
      mode="fluid-height"
      padding="0px"
      vertical-align="top"
    >
      <mj-text color="#fff5e8" font-size="24px" font-weight="700" line-height="30px">
        Launch week
      </mj-text>
      <mj-spacer height="10px" />
      <mj-text color="#e8d9ca" font-size="14px" line-height="22px">
        Hero blocks combine background treatment with real email content.
      </mj-text>
      <mj-spacer height="14px" />
      <mj-button
        align="left"
        background-color="#db7636"
        border-radius="999px"
        color="#fffaf2"
        href="https://example.com/dashboard"
        inner-padding="10px 16px"
      >
        Open dashboard
      </mj-button>
    </mj-hero>
  </mj-body>
</mjml>